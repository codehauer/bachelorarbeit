  booktitle = {2025 {{IEEE Ural-Siberian Conference}} on {{Biomedical Engineering}}, {{Radioelectronics}} and {{Information Technology}} ({{USBEREIT}})},
  author = {Zimin, Evgeny and Saichik, Evgenii and Arkhipov, Nikolay},
